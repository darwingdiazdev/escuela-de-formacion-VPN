# MongoDB (local o Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=gestion_notas

# API (Render usa PORT automáticamente)
API_PORT=3001
PORT=3001

# Firma de sesión web (cámbiala en producción)
AUTH_SECRET=cambia-este-secreto

# Orígenes permitidos (coma-separados). Vacío = permitir todos (solo desarrollo)
# CORS_ORIGIN=https://tu-app.onrender.com

# URL de la API para el frontend en desarrollo separado.
# En Render (API+web juntos) déjala vacía para usar el mismo origen.
# VITE_API_URL=http://localhost:3001
